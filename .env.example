# Root-level shared env vars.
# App-specific values live in each app's own .env.example.

# Sui network (used by every app)
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Keepra Move package (testnet package id from move/keepra/Published.toml)
KEEPRA_PACKAGE_ID=

# Walrus (shared; aggregators comma-separated, tried in order)
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATORS=https://aggregator.walrus-testnet.walrus.space,https://wal-aggregator-testnet.staketab.org,https://walrus-testnet-aggregator.nodes.guru,https://aggregator.testnet.walrus.atalma.io
WALRUS_EPOCHS=5
