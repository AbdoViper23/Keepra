# ─── Sui ───
NEXT_PUBLIC_SUI_NETWORK=testnet
# Public-fullnode fallback (used during SSR / if the /api/rpc proxy is bypassed).
NEXT_PUBLIC_SUI_RPC_URL=https://fullnode.testnet.sui.io:443
NEXT_PUBLIC_KEEPRA_PACKAGE_ID=0x2d35cf0d810e5d43df3e8332d7e7a464e44f41cfd644af23ad68efcf901ba7a4

# ─── Tatum Sui RPC (server-side only — proxied via app/api/rpc) ───
# Get a free key at https://dashboard.tatum.io. When set, all browser RPC is
# routed through Tatum's gateway (hackathon requirement). Leave blank to use the
# public fullnode. NEVER prefix this with NEXT_PUBLIC_ (it must stay server-side).
TATUM_API_KEY=
TATUM_SUI_RPC_URL=https://sui-testnet.gateway.tatum.io
SUI_RPC_FALLBACK_URL=https://fullnode.testnet.sui.io:443

# ─── Walrus ───
# Aggregators are comma-separated and tried in order (download fallback per Flows §8).
NEXT_PUBLIC_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_AGGREGATORS=https://aggregator.walrus-testnet.walrus.space,https://wal-aggregator-testnet.staketab.org,https://walrus-testnet-aggregator.nodes.guru,https://aggregator.testnet.walrus.atalma.io

# ─── Seal: Move Package (testnet) ───
NEXT_PUBLIC_SEAL_PACKAGE_ID=0x8d90881fc48eb30d4422db68083b49e7d0f879658444e3a0ed85ce47feaa54b2

# ─── Seal: Decentralized Committee Server (primary, recommended) ───
# Single logical server backed by a 3-of-5 MPC committee.
NEXT_PUBLIC_SEAL_COMMITTEE_SERVER_ID=0xb012378c9f3799fb5b1a7083da74a4069e3c3f1c93de0b27212a5799ce1e1e98
NEXT_PUBLIC_SEAL_COMMITTEE_AGGREGATOR_URL=https://seal-aggregator-testnet.mystenlabs.com

# ─── Seal: Independent Open-Mode Servers (for hybrid threshold; Phase 7+) ───
NEXT_PUBLIC_SEAL_INDEP_MYSTEN_1=0x73d05d62c18d9374e3ea529e8e0ed6161da1a141a94d3f76ae3fe4e99356db75
